---
title: 'Free Groups in Baltimore Pediatric Occupational Therapy, Erin Helms OTR/L, CLC'
description: 'Free Groups run by Tiny Tides Therapy Baltimore Pediatric Occupational Therapy'

import Service from '../components/Service.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
const markdownFiles = await Astro.glob('./groups/*md')

const groups = Object.values(markdownFiles)

const pageTitle = 'Groups'
---

<BaseLayout pageTitle={pageTitle}>
  <div class="relative w-full">
    <img
      src="https://dkbi9cj3nodif.cloudfront.net/tummy_time_in_park_riverside.jpg"
      alt="Toddlers playing"
      class="w-full h-full object-cover object-bottom contrast-125 max-h-[70vh]"
    />
    <h1
      class="header-title text-4xl sm:text-5xl text-white absolute w-3/5 sm:w-auto top-1/3 left-1/2 -translate-x-[50%] sm:-translate-x-[60%] bg-black/50 sm:px-4 py-2 rounded-md"
    >
      Groups
    </h1>
  </div>
  <div
    class="w-full flex flex-col gap-y-4 px-4 md:px-12 py-8 treat-item transition-all duration-300 ease-in-out"
  >
    {
      groups.map((group) => (
        <Service
          title={group.frontmatter.title}
          duration={group.frontmatter.duration}
          price={group.frontmatter.price}
          img={group.frontmatter.img}
          id={group.frontmatter.id}
        >
          <group.Content />
        </Service>
      ))
    }
  </div>
</BaseLayout>
