---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Button from '../../../components/Button.astro'
import { stripe } from '../../../lib/Stripe'

const { course: courseSlug } = Astro.params
const sessionId = Astro.url.searchParams.get('session_id')

if (!courseSlug) {
  return Astro.redirect('/404')
}

if (!sessionId) {
  return Astro.redirect(`/courses/${courseSlug}`)
}

let session
try {
  session = await stripe.checkout.sessions.retrieve(sessionId)
} catch (err) {
  console.error('Failed to retrieve checkout session', err)
  return Astro.redirect(`/courses/${courseSlug}`)
}

const paid =
  session.payment_status === 'paid' &&
  session.metadata?.course_slug === courseSlug

if (!paid) {
  return Astro.redirect(`/courses/${courseSlug}`)
}

const courseTitle = session.metadata?.course_title ?? 'your course'
const startPath = session.metadata?.start_path ?? `/courses/${courseSlug}`

const pageTitle = `You're enrolled - ${courseTitle}`
---

<BaseLayout pageTitle={pageTitle}>
  <div
    class="w-full bg-primary h-[76.7vh] flex flex-col gap-y-6 justify-center items-center px-4 text-center"
  >
    <span class="text-5xl">🎉</span>
    <h1 class="header-title text-blue-950">You're enrolled!</h1>
    <p class="text-2xl text-blue-950">
      Thanks for your purchase. You now have full access to the <span
        class="font-semibold">{courseTitle}</span
      > course.
    </p>
    <p class="text-base text-gray-700">
      A confirmation email is on its way to your inbox.
    </p>

    <a href={startPath}>
      <Button
        text="Start the Course"
        textColor="#173f69bf"
        textSize="text-xl"
      />
    </a>

    <a
      href="/profile/mycourses"
      class="text-sm text-gray-600 underline hover:text-gray-900"
    >
      Go to My Courses
    </a>
  </div>
</BaseLayout>
