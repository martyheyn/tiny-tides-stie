---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CourseLayout from '../../../layouts/CourseLayout.svelte'
import Video from '../../../components/courses/Video.svelte'
import { courseChapters } from '../../../utils/chapters'

const { course, chapter } = Astro.params

const pageTitle = `${course} - ${chapter}`

const chapters = course && courseChapters[course as keyof typeof courseChapters]
---

<BaseLayout pageTitle={pageTitle}>
    <CourseLayout client:load chapters={chapters}>

      <!-- Main Content -->
      <main class="flex-1 p-6">
        <!-- Video Area -->
        <Video client:load />


        <!-- Title -->
        <h1 class="mt-6 text-gray-800 text-3xl font-bold">
          ⚡ Chapter Name
        </h1>
      </main>
    </div>
    </CourseLayout>
</BaseLayout>
