---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Modal from '../../components/Modal.astro'
import Signin from '../../components/signin/Signin.svelte'
import PurchaseButton from '../../components/PurchaseButton.svelte'
import { createBEClient } from '../../lib/SupabaseServer'
import type { MarkdownInstance } from 'astro'

const { course: courseSlug } = Astro.params
const user = Astro.locals.user
const url = Astro.url
const supabase = createBEClient({ request: Astro.request, cookies: Astro.cookies })

// Load all markdown
const markdownFiles = import.meta.glob<MarkdownInstance<any>>('../courses-md/*md', { eager: true })
const allCourses = Object.values(markdownFiles).map((file) => ({
  content: file.compiledContent(),
  frontmatter: file.frontmatter,
}))

// Find this course
const courseData =
  allCourses.find((c) => c.frontmatter.slug === courseSlug) ?? null

if (!courseData) {
  return Astro.redirect("/404")
}

// Run these in parallel
const [chaptersRes, purchaseRes] = await Promise.all([
  supabase
    .from("section_with_progress")
    .select("*")
    .eq("course_id", courseData.frontmatter.id)
    .order("section_order"),
  user
    ? supabase
        .from("purchases")
        .select("id")
        .eq("user_id", user.id)
        .eq("course_id", courseData.frontmatter.id)
        .maybeSingle()
    : Promise.resolve({ data: null })
])

const chapters = chaptersRes.data ?? []
const alreadyPurchased = !!purchaseRes.data

// Clean helper for constructing the start URL
function startCourseUrl(slug: string, chapters: any) {
  if (!chapters.length || !chapters[0].videos.length) return "#"
  const c = chapters[0]
  const v = c.videos[0]
  return `/courses/${slug}/${c.slug}/${v.slug}`
}

const startUrl = startCourseUrl(courseData.frontmatter.slug, chapters)
console.log("startUrl", startUrl)
const pageTitle = courseData ? `Course - ${courseData.frontmatter.title}` : "Course"
---

<BaseLayout pageTitle={pageTitle}>
  <div
    class="w-full h-full px-4 sm:px-8 flex flex-col justify-center items-center relative"
  >
    <div class="max-w-5xl pb-24">
      {
        courseData ? (
          <>
            <header class="text-center mb-8 mt-20">
              <h1 class="text-[54px] mb-2 font-semibold">
                {courseData.frontmatter.title}
              </h1>
              <p class="text-[16px] my-0 text-gray-700">
                {courseData.frontmatter.description}
              </p>
            </header>
            <div class="mx-auto w-24 h-1 my-12 bg-gradient-to-r from-slate-100 to-slate-300 rounded-full" />

            <div class="w-full flex justify-center">
              <video
                controls controlslist="nodownload"
                src={`https://dkbi9cj3nodif.cloudfront.net/${courseData.frontmatter.preview_vid}` || ''}
                class="w-full md:w-[75%] min-h-[315px] md:min-h-[400px] bg-blue-300/30"
              />
            </div>

            <div class="w-full flex justify-center mt-20">
              {/* if logged in and purchased then go to course */}
              {alreadyPurchased ? (
                <a
                  href={startUrl}
                  class={`w-72 text-center font-semibold text-xl px-6 py-3 bg-[#9ddcdc] hover:bg-[#90e8e8] text-[#173f69bf] transition-all duration-300 ease-in-out cursor-pointer rounded-md hover:scale-[1.02] shadow-lg hover:shadow-2xl`}
                >
                  Go to the Course!
                </a>
              ) : (
                <PurchaseButton 
                  slug={courseSlug}
                  client:load
                />
              )}
            </div>

            <div class="mx-auto w-24 h-1 my-24 bg-gradient-to-r from-slate-100 to-slate-300 rounded-full" />

            <article set:html={courseData.content} />
          </>
        ) : null
      }
    </div>


    <div class="w-full flex justify-center py-8 pb-28">
      {alreadyPurchased ? (
        <a
          href={startUrl}
          class={`w-72 text-center font-semibold text-xl px-6 py-3 bg-[#9ddcdc] hover:bg-[#90e8e8] text-[#173f69bf] transition-all duration-300 ease-in-out cursor-pointer rounded-md hover:scale-[1.02] shadow-lg hover:shadow-2xl`}
        >
          Go to the Course!
        </a>
      ) : (
        <PurchaseButton 
          slug={courseSlug}
          client:load
        />
      )}
    </div>

    <div class="pb-24">
      <h1 class="text-4xl uppercase text-center font-semibold">Chapters</h1>
      <div
        class="mx-auto w-24 h-1 my-16 bg-gradient-to-r from-blue-200 to-blue-100 rounded-full"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          chapters &&
            chapters.map((chapter, i) => (
              <div class="max-w-sm overflow-hidden shadow-3xl bg-secondary/20 p-6 rounded-xl hover:scale-105 cursor-pointer transition-all duration-300 relative">
                <a href={chapter.videos && chapter.videos[0] && `${courseSlug}/${chapter.slug}/${chapter.videos[0].slug}`}>
                  <h5 class="text-xl uppercase font-semibold flex justify-start items-center">
                    <span class="mr-1 bg-white px-2 py-1 rounded-md flex justify-center">
                      {i + 1}
                    </span>
                    {chapter.label}
                  </h5>
                  <p class="my-5 text-base text-gray-700 ml-2">
                    {chapter.description}
                  </p>
                </a>
              </div>
            ))
        }
      </div>
    </div>

    {!alreadyPurchased && (
      <div class="get-course-btn w-full sticky bottom-1">
        <div class="flex justify-end">
          <button class="text-black opacity-40 hover:opacity-100 flex items-center gap-x-[6px] cursor-pointer hover:scale-[1.03] transition-all duration-300 ease-in-out">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" style="enable-background:new 0 0 128 128" xml:space="preserve"><path style="fill:#e9da10" d="M101.946 53.087h-75.88a3.903 3.903 0 0 0-3.891 3.891v64.207a3.903 3.903 0 0 0 3.891 3.891h75.881a3.903 3.903 0 0 0 3.891-3.891V56.978a3.904 3.904 0 0 0-3.892-3.891zM68.928 93.673v13.094h-7.374V93.673c-3.541-1.44-6.051-4.922-6.051-8.989 0-5.37 4.358-9.728 9.728-9.728s9.728 4.358 9.728 9.728a9.69 9.69 0 0 1-6.031 8.989z"/><path style="fill:#1d252c" d="M101.94 50.173h-7.25v-19.49C94.69 13.764 80.926 0 63.994 0 47.074 0 33.31 13.764 33.31 30.683v19.49h-7.25a6.818 6.818 0 0 0-6.81 6.81v64.207a6.818 6.818 0 0 0 6.81 6.81h75.881a6.818 6.818 0 0 0 6.81-6.81V56.983c-.001-3.754-3.056-6.81-6.811-6.81zm-62.793-19.49c0-13.7 11.146-24.846 24.858-24.846 13.701 0 24.847 11.146 24.847 24.846v19.49H39.147v-19.49zm63.766 90.507a.985.985 0 0 1-.973.973H26.06a.985.985 0 0 1-.973-.973V56.983c0-.527.445-.973.973-.973h75.881c.528 0 .973.446.973.973v64.207zM65.231 73.01c-6.437 0-11.674 5.237-11.674 11.674 0 4.309 2.335 8.189 6.052 10.217v11.868c0 1.075.87 1.946 1.946 1.946h7.374c1.075 0 1.946-.87 1.946-1.946V94.901c3.703-2.025 6.031-5.904 6.031-10.217-.001-6.437-5.237-11.674-11.675-11.674zm2.964 18.861a1.944 1.944 0 0 0-1.212 1.802v11.15H63.5v-11.15c0-.792-.479-1.504-1.212-1.802a7.73 7.73 0 0 1-4.839-7.187c0-4.291 3.49-7.783 7.783-7.783 4.292 0 7.783 3.491 7.783 7.783a7.722 7.722 0 0 1-4.82 7.187z"/></svg>
            <p class="text-[16px] mt-[4px]">
              Must be signed in to access course
            </p>
          </button>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<Modal id='signin-dialog' title="Signin Modal">
  <main slot='main'>
    <Signin url={url.pathname} client:load />
  </main>
  <button slot='close'>Close modal</button>
</Modal>