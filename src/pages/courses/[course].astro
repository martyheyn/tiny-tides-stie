---
import Button from '../../components/Button.astro';
import BaseLayout from '../../layouts/BaseLayout.astro'
import { courseChapters } from '../../utils/chapters'
import Modal from '../../components/Modal.astro'
import Signin from '../../components/signin/Signin.svelte';

import type { MarkdownInstance } from 'astro';

const { course } = Astro.params
const user = Astro.locals.user
const url = Astro.url;

const markdownFiles = import.meta.glob<MarkdownInstance<any>>('../courses-md/*md', { eager: true });

const courseMd = await Promise.all(
  Object.values(markdownFiles).map(async (file) => ({
    content: file.compiledContent(),
    frontmatter: file.frontmatter,
  }))
);

const courseData = courseMd.length > 0 ? courseMd[0] : null

const pageTitle = `Course ${courseData && `- ${courseData.frontmatter.title}`}`

const chapters = course && courseChapters[course as keyof typeof courseChapters]
---

<BaseLayout pageTitle={pageTitle}>
  <div
    class="w-full h-full px-4 sm:px-8 flex flex-col justify-center items-center"
  >
    <div class="max-w-5xl pb-24">
      {
        courseData ? (
          <>
            <header class="text-center mb-8 mt-20">
              <h1 class="text-[54px] mb-2 font-semibold">
                {courseData.frontmatter.title}
              </h1>
              <p class="text-[14px] my-0 text-gray-700">
                {courseData.frontmatter.description}
              </p>
            </header>
            <div class="mx-auto w-24 h-1 my-12 bg-gradient-to-r from-slate-100 to-slate-300 rounded-full" />

            <div class="w-full flex justify-center">
              <video
                src=""
                class="w-full md:w-[75%] min-h-[315px] md:min-h-[400px] bg-blue-300/30"
              />
            </div>

            <div class="w-full flex justify-center mt-20">
              {/* if logged in and purchased then go to course */}
              {/* on click if logged in and not purchased then straight to stripe */}
              {/* if not looged in then login modal */}
              <button
                class={`get-course-btn w-72 font-semibold text-xl px-6 py-3 bg-[#9ddcdc] hover:bg-[#90e8e8] text-[#173f69bf] transition-all duration-300 ease-in-out cursor-pointer rounded-md hover:scale-[1.02] shadow-lg hover:shadow-2xl`}
              >
                Get the Course Now!
              </button>
            </div>

            <div class="mx-auto w-24 h-1 my-24 bg-gradient-to-r from-slate-100 to-slate-300 rounded-full" />

            <article set:html={courseData.content} />
          </>
        ) : null
      }
    </div>


    <div class="w-full flex justify-center py-8 pb-28">
        <button
          class={`get-course-btn" w-72 font-semibold text-xl px-6 py-3 bg-[#9ddcdc] hover:bg-[#90e8e8] text-[#173f69bf] transition-all duration-300 ease-in-out cursor-pointer rounded-md hover:scale-[1.02] shadow-lg hover:shadow-2xl`}
        >
          Start Today!
        </button>
    </div>

    <div class="pb-24">
      <h1 class="text-4xl uppercase text-center font-semibold">Chapters</h1>
      <div
        class="mx-auto w-24 h-1 my-16 bg-gradient-to-r from-blue-200 to-blue-100 rounded-full"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          chapters &&
            chapters.map((chapter, i) => (
              <div class="max-w-sm overflow-hidden shadow-3xl bg-secondary/20 p-6 rounded-xl hover:scale-105 cursor-pointer transition-all duration-300 relative">
                <div class="absolute" />
                <a href={`${course}/${chapter.slug}`}>
                  <h5 class="text-xl uppercase font-semibold flex justify-start items-center">
                    <span class="mr-1 bg-white px-2 py-1 rounded-md flex justify-center">
                      {i + 1}
                    </span>
                    {chapter.title}
                  </h5>
                  <p class="my-5 text-base text-gray-700 ml-2">
                    {chapter.description}
                  </p>
                </a>
              </div>
            ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<Modal id='signin-dialog' title="Signin Modal">
  <main slot='main'>
    <Signin url={url.pathname} client:load />
  </main>
  <button slot='close'>Close modal</button>
</Modal>


<script define:vars={{ user }}>
  const modal = document.getElementById('signin-dialog');

  const getCourseBtns = document.getElementsByClassName("get-course-btn")
  console.log("getCourseBtns", getCourseBtns)

  if(modal && getCourseBtns) {
    getCourseBtns[0]?.addEventListener('click', (e) => {
      if(!user) {
        if(modal && getCourseBtns) {
          e.stopPropagation();
          if (!modal.open) modal.showModal();
        }
      }
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });

      if(user) {
        console.log("send em to stripe")
      }
    });
  }
</script>